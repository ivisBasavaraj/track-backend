      "name": "Master Tools",
      "item": [
        {
          "name": "Create Master Tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tool_id\": 5,\n  \"tool_name\": \"CARBIDE DRILL\",\n  \"holder_name\": \"ER32 100GPL\",\n  \"atc_pocket_no\": \"P05\",\n  \"tool_room_no\": \"0\",\n  \"tool_life_threshold\": 3000,\n  \"supervisor_email\": \"supervisor@company.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tool-life/master/create",
              "host": ["{{base_url}}"],
              "path": ["api", "tool-life", "master", "create"]
            }
          }
